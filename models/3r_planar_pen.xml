<mujoco model="3r_planar_pen_robot">
  <compiler angle="degree" coordinate="local" autolimits="true"/>

  <option timestep="0.002" integrator="RK4" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.5" armature="0.01"/>
    <geom condim="3" friction="0.8 0.1 0.1"/>
    <default class="link">
      <geom type="capsule" size="0.014" material="link_metal"/>
    </default>
    <default class="raised_link">
      <geom type="capsule" size="0.012" material="link_metal"/>
    </default>
    <default class="joint_housing">
      <geom type="cylinder" size="0.035 0.018" material="joint_metal"/>
    </default>
    <default class="joint_cap">
      <geom type="cylinder" size="0.039 0.006" material="cap_blue" contype="0" conaffinity="0"/>
    </default>
  </default>

  <asset>
    <material name="white_surface" rgba="1 1 1 1"/>
    <material name="pen_black" rgba="0.02 0.025 0.03 1"/>
    <material name="base_dark" rgba="0.18 0.19 0.2 1"/>
    <material name="joint_metal" rgba="0.42 0.45 0.45 1" specular="0.45" shininess="0.35"/>
    <material name="link_metal" rgba="0.74 0.77 0.75 1" specular="0.65" shininess="0.55"/>
    <material name="cap_blue" rgba="0.38 0.78 0.96 1" specular="0.25" shininess="0.2"/>
  </asset>

  <worldbody>
    <light name="key_light" pos="0 -0.6 1.2" dir="0 0.4 -1" diffuse="0.9 0.9 0.9"/>
    <camera name="top_view" pos="0.2 0 1.2" xyaxes="0 1 0 -1 0 0"/>
    <camera name="side_view" pos="0.25 -0.8 0.25" xyaxes="1 0 0 0 0 1"/>

    <geom name="writing_surface" type="plane" pos="0 0 0" size="0.45 0.45 0.01" material="white_surface"/>
    <site name="target_marker" pos="0.02 -0.32 0.006" size="0.01" rgba="1 0.1 0.1 1"/>

    <body name="base" pos="-0.32 -0.32 0.055">
      <geom name="base_plate" type="box" pos="0 0 -0.043" size="0.07 0.07 0.012" material="base_dark"/>
      <geom name="base_turntable" type="cylinder" pos="0 0 -0.022" size="0.052 0.014" material="joint_metal"/>
      <geom name="base_cap" class="joint_cap" pos="0 0 -0.004"/>

      <body name="link1" pos="0 0 0">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180"/>
        <geom name="link1_bar" class="link" fromto="0.040 0 0 0.100 0 0"/>
        <geom name="joint1_hub" class="joint_housing"/>
        <geom name="joint1_cap_top" class="joint_cap" pos="0 0 0.024"/>
        <geom name="joint1_cap_bottom" class="joint_cap" pos="0 0 -0.024"/>

        <body name="link2_bridge" pos="0.14 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-160 160"/>
          <geom name="joint2_hub" class="joint_housing"/>
          <geom name="joint2_cap_top" class="joint_cap" pos="0 0 0.024"/>
          <geom name="joint2_cap_bottom" class="joint_cap" pos="0 0 -0.024"/>
          <geom name="link2_riser_up" class="raised_link" fromto="0 0 0.036 0 0 0.064"/>
          <geom name="link2_raised_bar" class="raised_link" fromto="0 0 0.064 0.11 0 0.064"/>
          <geom name="link2_riser_down" class="raised_link" fromto="0.11 0 0.064 0.11 0 0.036"/>

          <body name="link3" pos="0.11 0 0">
            <joint name="joint3" type="hinge" axis="0 0 1" range="-180 180"/>
            <geom name="joint3_hub" class="joint_housing"/>
            <geom name="joint3_cap_top" class="joint_cap" pos="0 0 0.024"/>
            <geom name="joint3_cap_bottom" class="joint_cap" pos="0 0 -0.024"/>
            <geom name="link3_bar" class="link" fromto="0.040 0 0 0.125 0 0"/>

            <body name="pen" pos="0.125 0 0">
              <geom name="pen_body" type="capsule" fromto="0 0 0 0 0 -0.049" size="0.006" material="pen_black"/>
              <site name="pen_tip" pos="0 0 -0.055" size="0.006" rgba="0 0 0 1"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="joint1_motor" joint="joint1" gear="0.2" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="joint2_motor" joint="joint2" gear="0.2" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="joint3_motor" joint="joint3" gear="0.2" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>

  <keyframe>
    <key name="writing_pose" qpos="35 -50 45"/>
  </keyframe>
</mujoco>
